# BitAxe Data Collector configuration

# Comma-separated list of miner IPs on your local network
MINER_IPS=192.168.1.50

# Where the dashboard runs
DASHBOARD_URL=https://your-dashboard.example.com

# Must match the dashboard's API_KEY
API_KEY=change-me-too

# Polling / config refresh intervals (seconds)
#POLL_SECONDS=30
#CONFIG_REFRESH_SECONDS=60

# Local buffer + tuner memory (mount a volume here in Docker)
#DATA_DIR=/data

# Safety kill-switch: never let the tuner change miner settings,
# regardless of the dashboard configuration.
#TUNER_FORCE_DISABLED=false
